rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /branches/{branchKey}/people/{personId} {
      allow read: if true;

      // Admin (đăng nhập): toàn quyền ghi
      allow write: if request.auth != null;

      // Không đăng nhập: chỉ cho phép update các field liên hệ, check-in, avatar
      allow update: if request.auth == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['diaChiHienTai', 'soDienThoai', 'facebook', 'zalo', 'khac',
                       'checkInImages', 'checkInDates',
                       'checkInImage', 'checkInDate',
                       'hinhAnh', 'updatedAt']);
    }

    // Spouses (vợ/chồng ngoài họ Đỗ)
    match /spouses/{spouseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Chat messages
    match /chat-messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Timeline events
    match /timeline-events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User accounts
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }
  }
}
